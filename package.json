{
  "name": "@velocity-bpa/n8n-nodes-ondo-finance",
  "version": "1.0.0",
  "description": "n8n community node for Ondo Finance - tokenized real-world assets and DeFi protocols",
  "license": "SEE LICENSE IN LICENSE.md",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "lint": "eslint .",
    "lintfix": "eslint . --fix",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist/**/*"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@9.1.4",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.0.0",
    "n8n-workflow": "1.57.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0",
    "tsup": "^8.0.0"
  },
  "dependencies": {
    "axios": "^1.6.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "ondo",
    "finance",
    "defi",
    "tokenized-assets",
    "flux",
    "usdy",
    "ousg"
  ],
  "n8n": {
    "nodes": [
      "dist/nodes/OndoFinance/OndoFinance.node.js"
    ],
    "credentials": [
      "dist/credentials/OndoFinanceApi.credentials.js"
    ]
  }
}